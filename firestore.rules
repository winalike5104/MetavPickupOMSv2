rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions (Optimized with Custom Claims)
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSystemAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "windalike5104@gmail.com" || request.auth.token.email == "alan@pickup.system") && 
             request.auth.token.email_verified == true;
    }

    function isUserAdmin() {
      return isAuthenticated() && (request.auth.token.role == 'Admin' || isSystemAdmin());
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Horizontal Data Isolation: Check if user has access to a specific warehouse
    function hasWarehouseAccess(warehouseId) {
      return isAuthenticated() && 
             (request.auth.token.allowedWarehouses.hasAny(['*', warehouseId]) || isSystemAdmin());
    }

    // Check if only specific fields are being modified (Granular Write Control)
    function isOnlyUpdatingFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // ===============================================================
    // Layered Validation (Structural Checks Only)
    // ===============================================================

    function isValidUser(data) {
      return data.username is string && 
             data.name is string && 
             data.status in ['Active', 'Disabled'] &&
             data.permissions is list;
    }

    function isValidOrder(data) {
      return data.bookingNumber is string && 
             data.customerName is string && 
             data.status is string &&
             data.warehouseId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      // Limit read to owner or admin to protect PII
      allow read: if isAuthenticated() && (isOwner(userId) || isUserAdmin());
      
      // Writes managed by backend or System Admin
      allow write: if isSystemAdmin(); 
    }

    // Orders collection
    match /orders/{orderId} {
      // Data Isolation: Only see orders from allowed warehouses
      allow read: if isAuthenticated() && hasWarehouseAccess(resource.data.warehouseId);
      
      // Creation: Must have access to the target warehouse
      allow create: if isAuthenticated() && 
                    isValidOrder(request.resource.data) && 
                    hasWarehouseAccess(request.resource.data.warehouseId);
      
      // Update: Granular permissions
      allow update: if isAuthenticated() && 
                    (
                      isSystemAdmin() || 
                      (
                        hasWarehouseAccess(resource.data.warehouseId) &&
                        isValidOrder(request.resource.data) &&
                        // Prevent changing critical financial/identity fields for non-admins
                        (isUserAdmin() || isOnlyUpdatingFields(['warehouseStatus', 'pickingLog', 'notes', 'status']))
                      )
                    );
      
      allow delete: if isUserAdmin();
    }

    // SKUs collection
    match /skus/{skuId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    // Stores collection
    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    // Logs collection
    match /logs/{logId} {
      allow read: if isUserAdmin();
      allow create: if isAuthenticated();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.recipientUid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.recipientUid;
    }

    // Announcements
    match /announcements/{annId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    // User Groups
    match /userGroups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isUserAdmin();
    }

    // Bug Reports
    match /bug_reports/{reportId} {
      allow read: if isUserAdmin();
      allow create: if isAuthenticated();
    }

    // Unique Keys (Shadow collection for uniqueness)
    match /unique_keys/{keyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isUserAdmin();
    }
  }
}
