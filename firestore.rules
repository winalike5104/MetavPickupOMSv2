rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // 1. 全局策略：前端严禁直连写入
    // ===============================================================
    
    // 默认所有集合：允许前端读取（用于显示列表和详情），但禁止前端直接写入。
    // 所有的 增/删/改 操作必须通过你的 Express 后端（Admin SDK）完成。
    match /{document=**} {
      allow read: if true; 
      allow write: if false; 
    }

    // ===============================================================
    // 2. 核心集合逻辑 (其实由于前端 allow write: if false，以下校验主要是起文档参考作用)
    // ===============================================================

    // 订单集合
    match /orders/{orderId} {
      allow read: if true;
      // 这里的 write 为 false 确保了没人能跳过 API 伪造订单
      allow write: if false; 
    }

    // 门店配置
    match /stores/{storeId} {
      allow read: if true;
      allow write: if false;
    }

    // 库存/产品信息
    match /skus/{skuId} {
      allow read: if true;
      allow write: if false;
    }

    // ===============================================================
    // 3. 特殊例外（如果某些功能需要前端直连，可以在这里放开）
    // ===============================================================

    // 如果你允许员工在前端直接点击“已读”通知，可以放开这个
    match /notifications/{id} {
      allow read: if true;
      allow update: if true; // 仅允许更新，不允许创建或删除
    }

    // 系统日志：只允许写入（埋点），不允许前端读取或修改
    match /logs/{logId} {
      allow create: if true;
      allow read: if false; 
    }

    // 调试连接专用
    match /_connection_test_/{docId} {
      allow read, write: if true;
    }
  }
}
